From: DevBox UML arm64 Port
Subject: [PATCH] arm64: um: add asm/cpufeature.h stub to override x86 version

--- /dev/null
+++ b/arch/arm64/um/asm/cpufeature.h
@@ -0,0 +1,12 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * arch/arm64/um/asm/cpufeature.h
+ * Override arch/um/include/asm/cpufeature.h (which has x86 content).
+ * UML on arm64 does not use x86 CPU feature bits.
+ */
+#ifndef __UM_ARM64_ASM_CPUFEATURE_H
+#define __UM_ARM64_ASM_CPUFEATURE_H
+
+/* UML arm64: no x86 CPU feature infrastructure needed */
+
+#endif /* __UM_ARM64_ASM_CPUFEATURE_H */
+
